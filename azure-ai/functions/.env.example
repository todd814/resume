# Local development environment — copy to .env and populate values.
# Run scripts/setup-local-env.sh to generate .env automatically from
# live Terraform Cloud state and Azure Container App secrets.
#
# DO NOT commit .env — it is listed in .gitignore.

AZURE_SEARCH_ENDPOINT=https://<search-service-name>.search.windows.net
AZURE_SEARCH_KEY=<terraform output -raw search_admin_key>
AZURE_SEARCH_INDEX_NAME=resume-content

AZURE_INFERENCE_ENDPOINT=<az containerapp secret show --secret-name inference-endpoint>
AZURE_INFERENCE_KEY=<az containerapp secret show --secret-name inference-key>

# Comma-separated origins allowed to call the API.
# For local dev, include localhost ports your HTTP server uses.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
